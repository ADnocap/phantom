\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces (a)\nonbreakingspace Double sort: mean daily returns by volatility and Phantom tercile. The volatility column dominates (low-vol assets earn positive returns regardless of Phantom ranking), but Phantom's long-short spread is significant within mid-vol ($t\,{=}\,$2.6) and high-vol ($t\,{=}\,$4.1) terciles. (b)\nonbreakingspace Combining both signals yields the highest IC.}}{7}{figure.caption.23}\protected@file@percent }
\newlabel{fig:ortho}{{3}{7}{(a)~Double sort: mean daily returns by volatility and Phantom tercile. The volatility column dominates (low-vol assets earn positive returns regardless of Phantom ranking), but Phantom's long-short spread is significant within mid-vol ($t\,{=}\,$2.6) and high-vol ($t\,{=}\,$4.1) terciles. (b)~Combining both signals yields the highest IC}{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Distributional quality. (a)\nonbreakingspace PIT histogram (h=10d) is approximately uniform. (b)\nonbreakingspace Coverage calibration closely tracks the diagonal. (c)\nonbreakingspace Predicted $\sigma $ follows $\sqrt  {h}$ scaling at short horizons.}}{7}{figure.caption.24}\protected@file@percent }
\newlabel{fig:dist}{{4}{7}{Distributional quality. (a)~PIT histogram (h=10d) is approximately uniform. (b)~Coverage calibration closely tracks the diagonal. (c)~Predicted $\sigma $ follows $\sqrt {h}$ scaling at short horizons}{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Robustness. (a)\nonbreakingspace Monthly IC is positive in all 15 months. (b)\nonbreakingspace 60-day rolling Sharpe always positive (min=2.82). (c)\nonbreakingspace Turnover stable at 38\%.}}{7}{figure.caption.25}\protected@file@percent }
\newlabel{fig:robust}{{5}{7}{Robustness. (a)~Monthly IC is positive in all 15 months. (b)~60-day rolling Sharpe always positive (min=2.82). (c)~Turnover stable at 38\%}{figure.caption.25}{}}
